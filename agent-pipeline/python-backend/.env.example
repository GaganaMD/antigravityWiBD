# AI Pulse — Python Backend Environment Variables

# ── Gemini (cloud LLM) ────────────────────────────────────────────────────────
GEMINI_API_KEY=gemini_api_key_from_ai_studio

# ── WhatsApp MCP Bridge ───────────────────────────────────────────────────────
# Path to the cloned lharries/whatsapp-mcp repo
WHATSAPP_MCP_PATH=C:\Users\<user>\whatsapp-mcp

# ── GitHub Pages publish (optional) ──────────────────────────────────────────
GITHUB_OWNER=your-github-username
GITHUB_REPO=ai-pulse-newsletter
GITHUB_PERSONAL_ACCESS_TOKEN=github_pat_your_token_here
# GMAIL
GMAIL_USER=your gmail account
GMAIL_APP_PASSWORD=your gmail app password

# ── Model override (optional) ─────────────────────────────────────────────────
# Set to "ollama" to force local Gemma3 via Ollama
# MODEL=ollama
