# AI Pulse — Python Backend Environment Variables
# Copy this to .env and fill in your values

# ── Gemini (cloud LLM) ────────────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key-here

# ── WhatsApp MCP Bridge ───────────────────────────────────────────────────────
# Path to the cloned lharries/whatsapp-mcp repo
# Repo is already cloned at:
WHATSAPP_MCP_PATH=C:\Users\Sivasakthi.M\whatsapp-mcp

# ── GitHub Pages publish (optional) ──────────────────────────────────────────
GITHUB_OWNER=your-github-username
GITHUB_REPO=ai-pulse-newsletter
GITHUB_PERSONAL_ACCESS_TOKEN=your-github-pat-here

# ── Model override (optional) ─────────────────────────────────────────────────
# Set to "ollama" to force local Gemma3 via Ollama
# MODEL=ollama
